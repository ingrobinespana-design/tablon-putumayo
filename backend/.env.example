# URL de conexión a PostgreSQL (Railway te la da automáticamente al crear la base de datos)
DATABASE_URL=postgresql://usuario:clave@localhost:5432/ganaderia

# Clave para entrar al panel de administración — CÁMBIALA antes de desplegar
ADMIN_CLAVE=cambiar-esta-clave

# Carpeta donde se guardan las fotos subidas
UPLOAD_DIR=uploads
